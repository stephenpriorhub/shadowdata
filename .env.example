# ── Reused OxfordHub secrets (already set at Railway project level) ───────────
# Claude powers entity resolution + thesis synthesis. Required.
ANTHROPIC_API_KEY=sk-ant-...

# GitHub PAT — raises the GitHub connector's rate limit from 60/hr to 5000/hr.
# Optional: the GitHub connector still works unauthenticated, just rate-limited.
GITHUB_TOKEN=github_pat_...

# Polygon — enriches the company header (sector, market cap, homepage, logo) and
# validates the ticker. Optional: without it, identity falls back to SEC EDGAR.
POLYGON_API_KEY=

# OxfordHub auth — forwards the hub session cookie to gate routes to signed-in users.
HUB_URL=https://oxfordhub.app
# Server-to-server bypass for scripted/cron calls (same secret as brain-map's).
HUB_API_TOKEN=

# ── App config ───────────────────────────────────────────────────────────────
# Hub project id used by hub-nav.js and /api/me. Set in Railway.
NEXT_PUBLIC_HUB_PROJECT_ID=altedge

# Where the per-ticker resolved-entity + snapshot cache lives.
# Set to a Railway volume mount (e.g. /data) for persistence across deploys.
# DATA_DIR=/data

# SEC EDGAR requires a descriptive User-Agent on every request (their fair-use rule).
SEC_USER_AGENT=OxfordHub AltEdge (sprior@monumenttradersalliance.com)

# ── Optional free-tier connector keys ────────────────────────────────────────
# PatentsView (patents connector) now requires a free API key. Without it the
# patents connector degrades gracefully to "no-data". Request one at
# https://patentsview.org/apis (free).
PATENTSVIEW_API_KEY=

# Reddit connector uses the public JSON endpoint by default (no key). These are
# only needed if you hit rate limits and want authenticated OAuth access.
REDDIT_CLIENT_ID=
REDDIT_SECRET=

# ── Future phase (NOT used in v1) ────────────────────────────────────────────
# Brain vault writes are intentionally disabled in v1 (trading/market apps need
# publisher sign-off before teaching the brain — decision 2026-07-01).
# BRAIN_API_URL=https://brain.oxfordhub.app
# BRAIN_GITHUB_REPO=stephenpriorhub/brain
